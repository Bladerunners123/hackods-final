        "from pathlib import Path\n",
        "import json\n",
        "\n",
        "import pandas as pd\n",
        "import plotly.express as px\n",
        "import plotly.graph_objects as go\n",
        "\n",
        "DATA_DIR = Path(\"..\") / \"datos\" / \"processed\"\n",
        "GEO_PATH = Path(\"mexico_states.geojson\")\n",
        "\n",
        "palette = {\n",
        "    \"ink\": \"#000000\",\n",
        "    \"base_dark\": \"#083d53\",\n",
        "    \"base\": \"#11516b\",\n",
        "    \"base_2\": \"#266985\",\n",
        "    \"base_3\": \"#347894\",\n",
        "    \"base_4\": \"#5194b0\",\n",
        "    \"mist\": \"#e3e6e6\",\n",
        "    \"white\": \"#ffffff\",\n",
        "    \"gender\": \"#a20584\",\n",
        "    \"gender_2\": \"#b32598\",\n",
        "}\n",
        "\n",
        "datos = pd.read_csv(DATA_DIR / \"datos_estados.csv\")\n",
        "coeficientes = pd.read_csv(DATA_DIR / \"coeficientes_modelo.csv\")\n",
        "correlaciones = pd.read_csv(DATA_DIR / \"correlaciones_abandono.csv\")\n",
        "brecha_genero = pd.read_csv(DATA_DIR / \"brecha_genero_estados.csv\")\n",
        "\n",
        "cve_to_geo = {\n",
        "    1: \"MX-AGU\",\n",
        "    2: \"MX-BCN\",\n",
        "    3: \"MX-BCS\",\n",
        "    4: \"MX-CAM\",\n",
        "    5: \"MX-COA\",\n",
        "    6: \"MX-COL\",\n",
        "    7: \"MX-CHP\",\n",
        "    8: \"MX-CHH\",\n",
        "    9: \"MX-CMX\",\n",
        "    10: \"MX-DUR\",\n",
        "    11: \"MX-GUA\",\n",
        "    12: \"MX-GRO\",\n",
        "    13: \"MX-HID\",\n",
        "    14: \"MX-JAL\",\n",
        "    15: \"MX-MEX\",\n",
        "    16: \"MX-MIC\",\n",
        "    17: \"MX-MOR\",\n",
        "    18: \"MX-NAY\",\n",
        "    19: \"MX-NLE\",\n",
        "    20: \"MX-OAX\",\n",
        "    21: \"MX-PUE\",\n",
        "    22: \"MX-QUE\",\n",
        "    23: \"MX-ROO\",\n",
        "    24: \"MX-SLP\",\n",
        "    25: \"MX-SIN\",\n",
        "    26: \"MX-SON\",\n",
        "    27: \"MX-TAB\",\n",
        "    28: \"MX-TAM\",\n",
        "    29: \"MX-TLA\",\n",
        "    30: \"MX-VER\",\n",
        "    31: \"MX-YUC\",\n",
        "    32: \"MX-ZAC\",\n",
        "}\n",
        "\n",
        "with GEO_PATH.open(encoding=\"utf-8\") as fh:\n",
        "    mexico_geo = json.load(fh)\n",
        "\n",
        "geo_ids = {feature[\"id\"] for feature in mexico_geo[\"features\"]}\n",
        "\n",
        "datos[\"sin_internet_pct\"] = 100 - datos[\"internet_hogares_pct\"]\n",
        "datos[\"indice_vulnerabilidad\"] = (\n",
        "    (datos[\"pobreza_pct\"] + datos[\"sin_internet_pct\"]) / 2\n",
        ").round(2)\n",
        "datos[\"geo_id\"] = datos[\"cve_ent\"].map(cve_to_geo)\n",
        "\n",
        "missing_geo = datos.loc[datos[\"geo_id\"].isna(), \"estado\"].tolist()\n",
        "missing_shape = sorted(set(datos[\"geo_id\"].dropna()) - geo_ids)\n",
        "if missing_geo or missing_shape:\n",
        "    raise ValueError(\n",
        "        f\"Estados sin geometria: {missing_geo}. IDs no encontrados en GeoJSON: {missing_shape}\"\n",
        "    )\n",
        "\n",
        "top_ive = datos.nlargest(5, \"indice_vulnerabilidad\").sort_values(\"indice_vulnerabilidad\")\n",
        "estado_lider_ive = top_ive.iloc[-1]\n",
        "estado_lider_nombre = estado_lider_ive[\"estado\"]\n",
        "estado_lider_ive_val = f\"{estado_lider_ive['indice_vulnerabilidad']:.1f}\"\n",
        "estado_lider_pobreza = f\"{estado_lider_ive['pobreza_pct']:.1f}\"\n",
        "estado_lider_sin_internet = f\"{estado_lider_ive['sin_internet_pct']:.1f}\"\n",
        "\n",
        "coefs_m2 = (\n",
        "    coeficientes.loc[coeficientes[\"modelo\"] == \"Modelo 2\", [\"termino\", \"estimacion\"]]\n",
        "    .set_index(\"termino\")[\"estimacion\"]\n",
        "    .to_dict()\n",
        ")\n",
        "\n",
        "datos[\"abandono_predicho\"] = (\n",
        "    coefs_m2.get(\"Intercept\", 0)\n",
        "    + coefs_m2.get(\"pobreza_pct\", 0) * datos[\"pobreza_pct\"]\n",
        "    + coefs_m2.get(\"internet_hogares_pct\", 0) * datos[\"internet_hogares_pct\"]\n",
        "    + coefs_m2.get(\"rezago_edu_pct\", 0) * datos[\"rezago_edu_pct\"]\n",
        ").round(2)\n",
        "\n",
        "coeficientes_modelo_2 = (\n",
        "    coeficientes.loc[\n",
        "        (coeficientes[\"modelo\"] == \"Modelo 2\")\n",
        "        & (coeficientes[\"termino\"] != \"Intercept\"),\n",
        "        [\"termino\", \"estimacion\", \"p_value\"],\n",
        "    ]\n",
        "    .assign(abs_estimacion=lambda df: df[\"estimacion\"].abs())\n",
        "    .sort_values(\"abs_estimacion\", ascending=False)\n",
        ")\n",
        "\n",
        "termino_labels = {\n",
        "    \"pobreza_pct\": \"Pobreza\",\n",
        "    \"internet_hogares_pct\": \"Acceso a internet\",\n",
        "    \"rezago_edu_pct\": \"Rezago educativo\",\n",
        "}\n",
        "\n",
        "top_coef_terms = [\n",
        "    termino_labels.get(term, term)\n",
        "    for term in coeficientes_modelo_2[\"termino\"].head(2).tolist()\n",
        "]\n",
        "\n",
        "top_corr = correlaciones.sort_values(\"r_pearson\", key=lambda s: s.abs(), ascending=False).iloc[0]\n",
        "top_corr_label = {\n",
        "    \"brecha_genero\": \"Brecha de genero\",\n",
        "    \"internet_hogares_pct\": \"Acceso a internet\",\n",
        "    \"pobreza_pct\": \"Pobreza\",\n",
        "    \"pobreza_ext_pct\": \"Pobreza extrema\",\n",
        "    \"rezago_edu_pct\": \"Rezago educativo\",\n",
        "}.get(top_corr[\"variable\"], top_corr[\"variable\"])\n",
        "top_corr_r = float(top_corr[\"r_pearson\"])\n",
        "top_corr_r_text = f\"{top_corr_r:.3f}\"\n",
        "\n",
        "brecha_top = brecha_genero.iloc[0]\n",
        "brecha_genero_top = float(brecha_top[\"brecha_genero\"])\n",
        "genero_mas_afectado = \"hombres\" if brecha_genero_top > 0 else \"mujeres\"\n",
        "brecha_top_estado = brecha_top[\"estado\"]\n",
        "brecha_top_abs = f\"{abs(brecha_genero_top):.1f}\"\n",
        "\n",
        "brecha_plot = pd.DataFrame(\n",
        "    {\n",
        "        \"genero\": [\"Hombres\", \"Mujeres\"],\n",
        "        \"abandono\": [brecha_top[\"abandono_hombres\"], brecha_top[\"abandono_mujeres\"]],\n",
        "    }\n",
        ")\n",
        "\n",
        "coef_tabla = (\n",
        "    coeficientes_modelo_2.assign(\n",
        "        variable=lambda df: df[\"termino\"].map(termino_labels),\n",
        "        estimacion=lambda df: df[\"estimacion\"].map(lambda v: f\"{v:.3f}\"),\n",
        "        p_value=lambda df: df[\"p_value\"].map(lambda v: f\"{v:.3f}\"),\n",
        "    )[[\"variable\", \"estimacion\", \"p_value\"]]\n",
        "    .rename(columns={\"variable\": \"Variable\", \"estimacion\": \"Estimador\", \"p_value\": \"p-valor\"})\n",
        ")"
      ],
